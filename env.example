# 🕷️ MuffetBot — Variables de entorno
# NO subas este archivo a GitHub con tus datos reales
# En Railway configura estas variables en el panel de Settings > Variables

# Tu usuario de Twitch (el canal del bot)
TWITCH_BOT_USERNAME=elosoking1

# Tu OAuth token de Twitch (el que generaste en twitchtokengenerator)
# Formato: oauth:xxxxxxxxxxxxxxxxx
TWITCH_OAUTH_TOKEN=oauth:tu_token_aqui

# El canal donde va a escuchar el bot (sin #)
TWITCH_CHANNEL=elosoking1

# Tu API Key de Groq (la que generaste en groq.com)
GROQ_API_KEY=tu_groq_key_aqui
